<script lang="ts" setup>
import { ref } from 'vue'

const props = defineProps<{
  loading: boolean
  error: string
  currentResult: string
}>()

const fullscreenSrc = ref('')

function openFullscreen(src: string) {
  fullscreenSrc.value = src
}

function closeFullscreen() {
  fullscreenSrc.value = ''
}

function downloadImage(src: string) {
  uni.saveImageToPhotosAlbum({
    filePath: src,
    success: () => {
      uni.showToast({ title: '保存成功', icon: 'success' })
    },
    fail: () => {
      uni.showToast({ title: '保存失败', icon: 'error' })
    },
  })
}
</script>

<template>
  <div class="result-area">
    <div v-if="error" class="error-banner">
      <text class="error-text">⚠️ {{ error }}</text>
    </div>

    <div v-if="loading" class="loading-state">
      <progress class="spinner" type="circle" :percent="0" stroke-width="4" color="#667eea" />
      <text>正在为你创作图片…</text>
    </div>

    <div v-if="currentResult && !loading" class="result-display">
      <div class="result-image-wrapper" @click="openFullscreen(currentResult)">
        <image :src="currentResult" class="result-image" mode="aspectFit" />
        <div class="fullscreen-hint">
          <text>🔍 点击全屏预览</text>
        </div>
      </div>
      <div class="result-actions">
        <button class="download-btn" @click.stop="downloadImage(currentResult)">
          <text>📥 下载图片</text>
        </button>
      </div>
    </div>

    <div v-if="!currentResult && !loading && !error" class="empty-state">
      <text class="empty-icon">🖼️</text>
      <text class="empty-text">你的作品将在这里展示</text>
      <text class="empty-sub">输入描述，点击生成开始创作</text>
    </div>

    <div v-if="fullscreenSrc" class="fullscreen-overlay" @click="closeFullscreen">
      <image :src="fullscreenSrc" class="overlay-image" mode="aspectFit" />
    </div>
  </div>
</template>

