  gap: 8px;
}

.slot-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.slot-label {
  font-size: 13px;
  font-weight: 600;
  color: #555;
}

.remove-btn {
  padding: 2px 8px;
  border: none;
  border-radius: 6px;
  background: rgba(245, 108, 108, 0.1);
  color: #f56c6c;
  font-size: 14px;
}

.generate-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  padding: 14px 24px;
  border: none;
  border-radius: 14px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 16px;
  font-weight: 600;
  box-shadow: 0 4px 16px rgba(102, 126, 234, 0.3);
}

.generate-btn:disabled {
  opacity: 0.5;
}

.generate-btn:active:not(:disabled) {
  opacity: 0.85;
}

@media (max-width: 640px) {
  .duration-buttons {
    flex-wrap: wrap;
  }

  .dur-btn {
    flex: 1 1 calc(50% - 4px);
  }
}
</style>
