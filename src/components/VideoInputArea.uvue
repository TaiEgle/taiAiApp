  padding: 4px 12px;
  border: none;
  border-radius: 8px;
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
  font-size: 13px;
  font-weight: 500;
}

.image-slot {
  background: rgba(255, 255, 255, 0.5);
  border-radius: 14px;
  padding: 14px;
  border: 1px solid rgba(255, 255, 255, 0.4);
  display: flex;
