  display: flex;
  gap: 8px;
}

.dur-btn {
  flex: 1;
  padding: 8px 12px;
  border: 1px solid rgba(200, 200, 200, 0.4);
  border-radius: 10px;
  background: rgba(255, 255, 255, 0.6);
  color: #666;
  font-size: 13px;
